APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENROUTER_API_KEY=""

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_LORE_COLLECTION=historia_lore
QDRANT_PLAYER_COLLECTION=player_matchmaking

NGROK_TOKEN=

# ── Bot Alpha (tier 1 — slash commands) ──────────────────────────────────────
# Credenciales del bot principal. Requeridas para el funcionamiento base.
DISCORD_PUBLIC_KEY=
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI="${APP_URL}/auth/discord/callback"
DISCORD_SYNC_URL=
DISCORD_BOT_REDIRECT_URI="${APP_URL}/invite/bot/callback"
DISCORD_BOT_PERMISSIONS=
DISCORD_STATELESS=true

# ── Bot Beta (tier 2 — entrevista en hilo privado) ────────────────────────────
# Dejar vacío si Bot Beta no está configurado. El sistema hace fallback a Alpha.
# Una vez configurado, cambiar autostart=false → true en supervisord.conf
# y ejecutar: supervisorctl start discord-gateway-beta
DISCORD_APP_ID_BETA=
DISCORD_PUBLIC_KEY_BETA=
DISCORD_BOT_TOKEN_BETA=

# ── OAuth y bot-invite para la app Beta ──────────────────────────────────────
# Estos valores corresponden a la aplicación Discord Beta en el portal de developers.
# Las rutas de callback deben registrarse en Discord Developer Portal → OAuth2 → Redirects.
DISCORD_CLIENT_ID_BETA=
DISCORD_CLIENT_SECRET_BETA=
DISCORD_REDIRECT_URI_BETA="${APP_URL}/auth/discord-beta/callback"
DISCORD_SYNC_URL_BETA=
DISCORD_BOT_REDIRECT_URI_BETA="${APP_URL}/invite/bot-beta/callback"
DISCORD_BOT_PERMISSIONS_BETA=
DISCORD_STATELESS_BETA=true

# ── Bot Gamma (tier 3 — llamadas de voz, futuro) ──────────────────────────────
# Reservado. No implementado todavía. Ver docs/plan_bot_gamma.md
DISCORD_APP_ID_GAMMA=
DISCORD_PUBLIC_KEY_GAMMA=
DISCORD_BOT_TOKEN_GAMMA=
DISCORD_CLIENT_ID_GAMMA=
DISCORD_CLIENT_SECRET_GAMMA=
DISCORD_REDIRECT_URI_GAMMA="${APP_URL}/auth/discord-beta/callback"
DISCORD_SYNC_URL_GAMMA=
DISCORD_BOT_REDIRECT_URI_GAMMA="${APP_URL}/invite/bot-beta/callback"
DISCORD_BOT_PERMISSIONS_GAMMA=
DISCORD_STATELESS_GAMMA=true

ADMIN_EMAIL=
ADMIN_PASSWORD=

# Activa Xdebug
#SAIL_XDEBUG_MODE=develop,debug
SAIL_XDEBUG_MODE=off
# Le dice a Xdebug cómo comunicarse con el host (WSL)
SAIL_XDEBUG_CONFIG="client_host=host.docker.internal client_port=9003 idekey=PHPSTORM start_with_request=yes"

OPENAI_API_KEY=
# --- INFRAESTRUCTURA AMD HACKATHON ---
DO_TOKEN=""
HF_TOKEN=""
DO_SSH_KEY_ID=""
VLLM_BASE_URL=""

#-google
GOOGLE_API_KEY=

#-speechmatic

SPEECHMATICS_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# VARIABLES NUEVAS — agregadas en Sprint-3/4 (HU-003 subdomain routing,
# HU-004 docker-compose producción). No existían en el .env.example original.
# ══════════════════════════════════════════════════════════════════════════════

# ── Subdomain routing (HU-003) ────────────────────────────────────────────────
# Dominio base sin protocolo. En local: localhost (se deriva de APP_URL si no se setea).
# En producción: mudrais.com
APP_BASE_DOMAIN=localhost

# Dominio de la cookie de sesión. El punto inicial comparte la sesión entre subdominios.
# En local: null (cookie scoped al host exacto).
# En producción: .mudrais.com
# SESSION_DOMAIN ya existe arriba — este comentario documenta el cambio de comportamiento.

# ── Seguridad de cookies (HU-003) ─────────────────────────────────────────────
# En local: false (HTTP). En producción: true (HTTPS obligatorio).
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ── Sanctum stateful domains (HU-003) ────────────────────────────────────────
# En local: vacío (Sanctum usa APP_URL automáticamente).
# En producción: mudrais.com,app.mudrais.com
SANCTUM_STATEFUL_DOMAINS=

# ── AI Providers nuevos (AMD / Embedding) ────────────────────────────────────
AMD_API_KEY=
EMBEDDING_API_KEY=

# ── Voice Bridge ──────────────────────────────────────────────────────────────
# Idioma por defecto para transcripción Speechmatics (es / en).
SPEECHMATICS_LANGUAGE=es