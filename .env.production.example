# ─────────────────────────────────────────────────────────────────────────────
# MUDRAIS — Production Environment Template
# Copy to laravel_app/.env on the server and fill in real values.
# NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=MUDRAIS
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://app.mudrais.com
APP_BASE_DOMAIN=mudrais.com

# ── Session & Cookies ─────────────────────────────────────────────────────────
# Leading dot enables cookie sharing across all subdomains of mudrais.com
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.mudrais.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=mudrais.com,app.mudrais.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mudrais
DB_USERNAME=mudrais
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Cache & Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=redis

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mudrais.com
MAIL_FROM_NAME="MUDRAIS"

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# Redirect URI in Discord Developer Portal must be:
#   https://app.mudrais.com/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_REDIRECT_URI=https://app.mudrais.com/auth/discord/callback

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
AMD_API_KEY=
EMBEDDING_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=warning
