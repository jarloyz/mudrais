# ─────────────────────────────────────────────────────────────────────────────
# MUDRAIS — Production Environment Template
# Copy to laravel_app/.env on the server and fill in real values.
# NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=MUDRAIS
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://app.mudrais.com
APP_BASE_DOMAIN=mudrais.com
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# ── Session & Cookies ─────────────────────────────────────────────────────────
# Leading dot enables cookie sharing across all subdomains of mudrais.com
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.mudrais.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=false
SESSION_PATH=/

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=mudrais.com,app.mudrais.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mudrais
DB_USERNAME=mudrais
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
REDIS_CLIENT=phpredis

# ── Cache & Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=redis

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_LORE_COLLECTION=historia_lore
QDRANT_PLAYER_COLLECTION=players_profiles

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mudrais.com
MAIL_FROM_NAME="MUDRAIS"

# ── Admin (Filament — primer usuario al seedear) ──────────────────────────────
ADMIN_EMAIL=admin@mudrais.com
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Discord — Producción ──────────────────────────────────────────────────────
# Redirect URIs en Discord Developer Portal:
#   https://app.mudrais.com/auth/discord/callback
#   https://app.mudrais.com/invite/bot/callback
DISCORD_APP_ID=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_REDIRECT_URI=https://app.mudrais.com/auth/discord/callback
DISCORD_BOT_REDIRECT_URI=https://app.mudrais.com/invite/bot/callback
DISCORD_BOT_PERMISSIONS=
DISCORD_SYNC_URL=https://app.mudrais.com/api/discord/interactions
DISCORD_STATELESS=false

# ── Discord — Beta ────────────────────────────────────────────────────────────
DISCORD_APP_ID_BETA=
DISCORD_CLIENT_ID_BETA=
DISCORD_CLIENT_SECRET_BETA=
DISCORD_BOT_TOKEN_BETA=
DISCORD_PUBLIC_KEY_BETA=
DISCORD_REDIRECT_URI_BETA=https://app.mudrais.com/auth/discord-beta/callback
DISCORD_BOT_REDIRECT_URI_BETA=https://app.mudrais.com/invite/bot-beta/callback
DISCORD_BOT_PERMISSIONS_BETA=
DISCORD_SYNC_URL_BETA=https://app.mudrais.com/api/discord/interactions
DISCORD_STATELESS_BETA=false

# ── Discord — Gamma (Voice) ───────────────────────────────────────────────────
DISCORD_APP_ID_GAMMA=
DISCORD_CLIENT_ID_GAMMA=
DISCORD_CLIENT_SECRET_GAMMA=
DISCORD_BOT_TOKEN_GAMMA=
DISCORD_PUBLIC_KEY_GAMMA=
DISCORD_REDIRECT_URI_GAMMA=https://app.mudrais.com/auth/discord-gamma/callback
DISCORD_BOT_REDIRECT_URI_GAMMA=https://app.mudrais.com/invite/bot-gamma/callback
DISCORD_BOT_PERMISSIONS_GAMMA=
DISCORD_SYNC_URL_GAMMA=https://app.mudrais.com/api/discord/interactions
DISCORD_STATELESS_GAMMA=false

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
AMD_API_KEY=
EMBEDDING_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
HF_TOKEN=
VLLM_BASE_URL=

# ── Voice Bridge (Speechmatics) ───────────────────────────────────────────────
SPEECHMATICS_API_KEY=
SPEECHMATICS_LANGUAGE=es

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

# ── Seguridad ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
